#include<iostream>
using namespace std;

int main(){
    int n;
    cin >> n;

    bool prime[n+1];

    // Step 1: assume all are prime
    for(int i = 0; i <= n; i++){
        prime[i] = true;
    }

    prime[0] = prime[1] = false;

    // Step 2: sieve logic
    for(int i = 2; i*i <= n; i++){
        if(prime[i]){
            for(int j = i*i; j <= n; j += i){
                prime[j] = false;
            }
        }
    }

    // Step 3: print primes
    for(int i = 2; i <= n; i++){
        if(prime[i]){
            cout << i << " ";
        }
    }

    return 0;
}
